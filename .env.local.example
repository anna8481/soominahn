# Copy to .env.local and fill in real values.
# In Vercel, set these as Environment Variables (Settings → Environment Variables).

# --- Supabase ---------------------------------------------------------------
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — SERVER ONLY. Never expose. Used for admin writes & uploads.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Admin auth ------------------------------------------------------------
# The password you'll type at /admin/login
ADMIN_PASSWORD=change-me

# Random string used to sign session cookies. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=change-me-to-a-long-random-string
